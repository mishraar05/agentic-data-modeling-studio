{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:knowledge:source-registry:1.0",
  "title": "Knowledge source registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_id", "registry_version", "approval_state", "runtime_eligible", "verified_at", "sources"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "registry_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
    "registry_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "approval_state": {"enum": ["CANDIDATE", "APPROVED", "REJECTED", "SUPERSEDED"]},
    "runtime_eligible": {"type": "boolean"},
    "verified_at": {"type": "string", "format": "date"},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "publisher", "url", "source_class", "usage_basis"],
        "properties": {
          "source_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "publisher": {"type": "string", "minLength": 1},
          "url": {"type": "string", "minLength": 1},
          "secondary_url": {"type": "string", "minLength": 1},
          "source_class": {"type": "string", "minLength": 1},
          "applicability": {"type": "string", "minLength": 1},
          "usage_basis": {"type": "string", "minLength": 1},
          "effective_from": {"type": "string", "format": "date"},
          "effective_to": {"type": "string", "format": "date"},
          "entitlement_reference": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
