{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:knowledge:pack-manifest:1.0",
  "title": "Knowledge pack manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pack_id", "pack_version", "approval_state", "runtime_eligible", "immutable", "scope", "modules", "assets"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "pack_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
    "pack_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "title": {"type": "string", "minLength": 1},
    "approval_state": {"enum": ["CANDIDATE", "APPROVED", "REJECTED", "SUPERSEDED"]},
    "runtime_eligible": {"type": "boolean"},
    "immutable": {"const": true},
    "created_at": {"type": "string", "format": "date"},
    "owner": {"type": "string", "minLength": 1},
    "scope": {"type": "object", "required": ["geography", "lob", "domains"], "properties": {"geography": {"type": "string"}, "lob": {"type": "string"}, "domains": {"type": "array", "items": {"type": "string"}, "minItems": 1}}},
    "precedence": {"type": "array", "items": {"type": "string"}},
    "source_registry": {"type": "string"},
    "completeness": {"type": "string"},
    "standards": {"type": "array", "items": {"type": "string"}},
    "references": {"type": "array", "items": {"type": "string"}},
    "modules": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["module_id", "path", "sha256"], "properties": {"module_id": {"type": "string"}, "path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}},
    "assets": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}},
    "legacy_inputs": {"type": "array", "items": {"type": "string"}},
    "prohibitions": {"type": "array", "items": {"type": "string"}}
  }
}
