{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:contract:common:0.3.0",
  "$comment": "Shared Increment-1 structural vocabulary and reusable record blocks. Trust, provenance and lifecycle vocabularies are contract-owned invariants. Domain vocabulary is referenced through governed_code_ref and is never copied into this file.",
  "$defs": {
    "envelope": {
      "type": "object",
      "required": [
        "record_id",
        "schema_version",
        "engagement_id",
        "lob",
        "domain",
        "artifact_version",
        "lifecycle_state",
        "provenance",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "record_id": {"type": "string", "minLength": 1},
        "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "engagement_id": {"type": "string", "minLength": 1},
        "lob": {"type": "string", "minLength": 1},
        "domain": {"type": "string", "minLength": 1},
        "artifact_version": {"type": "string", "minLength": 1},
        "lifecycle_state": {"type": "string", "minLength": 1},
        "provenance": {"$ref": "#/$defs/provenance"},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "provenance": {
      "$comment": "Evidence may exist before Increment-3 context assembly, so context_snapshot_id is optional here. Context-dependent artifact schemas must narrow provenance with contextual_provenance.",
      "type": "object",
      "required": ["work_package_id", "run_id"],
      "properties": {
        "work_package_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "context_snapshot_id": {"type": "string", "minLength": 1},
        "source_snapshot_id": {"type": "string", "minLength": 1},
        "profile_snapshot_id": {"type": "string", "minLength": 1},
        "model_version": {"type": "string", "minLength": 1},
        "prompt_version": {"type": "string", "minLength": 1},
        "skill_version": {"type": "string", "minLength": 1},
        "tool_version": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "contextual_provenance": {
      "allOf": [
        {"$ref": "#/$defs/provenance"},
        {"required": ["context_snapshot_id"]}
      ]
    },
    "lifecycle_material": {
      "enum": ["DRAFT", "APPROVED", "REJECTED", "SUPERSEDED"]
    },
    "lifecycle_append_only": {
      "enum": ["COMMITTED", "SUPERSEDED"]
    },
    "lifecycle_operational": {
      "enum": ["ACTIVE", "CLOSED", "REJECTED", "SUPERSEDED"]
    },
    "lifecycle_governance_decision": {
      "enum": ["RECORDED", "SUPERSEDED"]
    },
    "lifecycle_open_item": {
      "enum": ["OPEN", "RESOLVED", "SUPERSEDED"]
    },
    "lifecycle_handoff": {
      "enum": ["DRAFT", "ISSUED", "REVOKED", "SUPERSEDED"]
    },
    "no_op_guard": {},
    "material_approval_guard": {
      "if": {"properties": {"lifecycle_state": {"const": "APPROVED"}}, "required": ["lifecycle_state"]},
      "then": {"required": ["review_decision_ref"]}
    },
    "handoff_issue_guard": {
      "if": {"properties": {"lifecycle_state": {"const": "ISSUED"}}, "required": ["lifecycle_state"]},
      "then": {"required": ["review_decision_ref", "handoff_fingerprint"]}
    },
    "evidence_state": {
      "enum": ["OBSERVED", "INFERRED", "DECIDED", "UNRESOLVED"]
    },
    "provenance_class": {
      "enum": ["SOURCE_FACT", "DOCUMENT_CLAIM", "GOVERNED_INPUT", "REQUIREMENT", "INFERENCE", "HUMAN_DECISION", "UNRESOLVED"]
    },
    "governed_code_ref": {
      "type": "object",
      "required": ["pack_id", "pack_version", "code_set_id", "fingerprint", "code"],
      "properties": {
        "pack_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "pack_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "code_set_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "code": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "confidence_components": {
      "type": "object",
      "required": ["evidence_type", "evidence_count", "critic_agreement"],
      "properties": {
        "evidence_type": {"enum": ["DECLARED_CONSTRAINT", "PROFILING_STATISTIC", "GLOSSARY_MATCH", "SINGLE_LLM_INFERENCE"]},
        "evidence_count": {"type": "integer", "minimum": 1},
        "critic_agreement": {"enum": ["CONFIRMED", "CONTESTED", "NOT_ASSESSED"]}
      },
      "additionalProperties": false
    },
    "scalar_value": {
      "oneOf": [
        {"type": "string", "minLength": 1},
        {"type": "number"},
        {"type": "boolean"}
      ]
    },
    "list_value": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/scalar_value"}
    },
    "mapping_entry": {
      "type": "object",
      "required": ["key", "value"],
      "properties": {
        "key": {"type": "string", "minLength": 1},
        "value": {"$ref": "#/$defs/scalar_value"}
      },
      "additionalProperties": false
    },
    "mapping_value": {
      "type": "object",
      "required": ["entries"],
      "properties": {
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/mapping_entry"}
        }
      },
      "additionalProperties": false
    },
    "cardinality_value": {
      "type": "object",
      "required": ["minimum", "maximum"],
      "properties": {
        "minimum": {"type": "integer", "minimum": 0},
        "maximum": {"type": ["integer", "null"], "minimum": 1}
      },
      "additionalProperties": false
    },
    "semantic_claim": {
      "type": "object",
      "required": ["evidence_state"],
      "properties": {
        "value": {
          "oneOf": [
            {"$ref": "#/$defs/scalar_value"},
            {"$ref": "#/$defs/list_value"},
            {"$ref": "#/$defs/mapping_value"},
            {"$ref": "#/$defs/cardinality_value"}
          ]
        },
        "value_type": {"enum": ["TEXT", "NUMBER", "BOOLEAN", "LIST", "MAPPING", "CARDINALITY", "CODE_VALUE", "KEY_ROLE", "PRIVACY_CLASS", "RETENTION_RULE"]},
        "governed_code_ref": {"$ref": "#/$defs/governed_code_ref"},
        "evidence_state": {"$ref": "#/$defs/evidence_state"},
        "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "review_decision_ref": {"type": "string", "minLength": 1},
        "open_question_ref": {"type": "string", "minLength": 1},
        "confidence": {"$ref": "#/$defs/confidence_components"},
        "assumptions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "contradictions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "allOf": [
        {
          "if": {"properties": {"evidence_state": {"enum": ["OBSERVED", "INFERRED", "DECIDED"]}}, "required": ["evidence_state"]},
          "then": {"required": ["value_type", "value"]}
        },
        {
          "if": {"properties": {"evidence_state": {"const": "UNRESOLVED"}}, "required": ["evidence_state"]},
          "then": {
            "required": ["open_question_ref"],
            "not": {"anyOf": [{"required": ["value"]}, {"required": ["value_type"]}, {"required": ["governed_code_ref"]}]}
          }
        },
        {
          "if": {"properties": {"evidence_state": {"const": "OBSERVED"}}, "required": ["evidence_state"]},
          "then": {"required": ["evidence_refs"]}
        },
        {
          "if": {"properties": {"evidence_state": {"const": "INFERRED"}}, "required": ["evidence_state"]},
          "then": {"required": ["evidence_refs", "confidence"]}
        },
        {
          "if": {"properties": {"evidence_state": {"const": "DECIDED"}}, "required": ["evidence_state"]},
          "then": {"required": ["review_decision_ref"]}
        },
        {
          "if": {"properties": {"value_type": {"enum": ["CODE_VALUE", "KEY_ROLE", "PRIVACY_CLASS", "RETENTION_RULE"]}}, "required": ["value_type"]},
          "then": {"required": ["governed_code_ref"]}
        }
      ],
      "additionalProperties": false
    },
    "physical_observation": {
      "type": "object",
      "required": ["value", "value_type", "evidence_refs"],
      "properties": {
        "value": {"$ref": "#/$defs/scalar_value"},
        "value_type": {"enum": ["TEXT", "NUMBER", "BOOLEAN"]},
        "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    }
  }
}
