{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:contract:solution_run:0.3.0",
  "$comment": "Top-level bounded execution and source-scope record. It replaces engagement/work-package identity with one run-rooted control boundary.",
  "type": "object",
  "allOf": [
    {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/envelope"},
    {
      "properties": {
        "schema_version": {"const": "0.3.0"},
        "lifecycle_state": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/lifecycle_operational"},
        "provenance": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/provenance"},
        "workflow_state": {"enum": ["VALIDATED", "METADATA_READY", "PROFILE_READY", "EVIDENCE_READY", "CONTEXT_READY", "SDD_READY", "SILVER_READY", "GOLD_READY", "STTM_READY", "PUBLISHED"]},
        "source_catalog": {"type": "string", "minLength": 1},
        "source_schema": {"type": "string", "minLength": 1},
        "source_tables": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-zA-Z0-9_]+$"}},
        "source_product": {"type": "string"},
        "source_module": {"type": "string"},
        "source_version": {"type": "string"},
        "knowledge_pack_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "knowledge_pack_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "output_catalog": {"type": "string", "minLength": 1},
        "output_schema": {"type": "string", "minLength": 1},
        "profiling_policy": {"enum": ["FULL", "METADATA_ONLY", "RESTRICTED"]},
        "run_type": {
          "type": "string",
          "enum": ["VALIDATE", "METADATA", "PROFILE", "EVIDENCE", "CONTEXT", "SDD", "REVIEW"],
          "description": "Type of solution execution"
        },
        "start_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the run started"
        },
        "end_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the run completed or failed"
        },
        "status": {
          "type": "string",
          "enum": ["RUNNING", "COMPLETED", "FAILED", "CANCELLED"],
          "description": "Current execution status"
        },
        "error_message": {
          "type": "string",
          "description": "Error details if status is FAILED"
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0,
          "description": "Approximate compute cost in USD for this run"
        }
      },
      "required": ["workflow_state", "source_catalog", "source_schema", "source_tables", "output_catalog", "output_schema", "profiling_policy", "run_type", "start_timestamp", "end_timestamp", "status"]
    },
    {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/no_op_guard"}
  ],
  "unevaluatedProperties": false
}
