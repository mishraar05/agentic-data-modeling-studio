{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:contract:profile_snapshot:0.1.0",
  "$comment": "Immutable point-in-time record of data profiling execution and fingerprint for lineage tracking.",
  "type": "object",
  "allOf": [
    {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/envelope"},
    {
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "lifecycle_state": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/lifecycle_append_only"},
        "provenance": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/provenance"},
        "source_snapshot_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to the source snapshot that was profiled"
        },
        "profiling_mode": {
          "type": "string",
          "enum": ["FULL", "METADATA_ONLY", "RESTRICTED"],
          "description": "Extent of profiling performed"
        },
        "profile_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of profile execution"
        },
        "profiled_table_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of tables profiled"
        },
        "profiled_attribute_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of attributes profiled"
        },
        "profile_query_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to query execution that generated this profile"
        },
        "fingerprint": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$",
          "description": "SHA-256 hash of profiling results for verification"
        }
      },
      "required": ["source_snapshot_ref", "profiling_mode", "profile_timestamp", "profiled_table_count", "profiled_attribute_count", "profile_query_ref", "fingerprint"]
    },
    {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/no_op_guard"}
  ],
  "unevaluatedProperties": false
}
