{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:contract:review_decision:0.1.0",
  "$comment": "Governance decision on a review item, controlling material artifact approval.",
  "type": "object",
  "allOf": [
    {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/envelope"},
    {
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "lifecycle_state": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/lifecycle_governance_decision"},
        "provenance": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/provenance"},
        "review_item_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to the review item"
        },
        "decision": {
          "type": "string",
          "enum": ["APPROVE", "REJECT", "REVISE", "DEFER"],
          "description": "The decision made"
        },
        "decision_maker": {
          "type": "string",
          "minLength": 1,
          "description": "Email or identifier of decision maker"
        },
        "decision_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of decision"
        },
        "rationale": {
          "type": "string",
          "minLength": 10,
          "description": "Explanation for the decision"
        },
        "impact_scope": {
          "type": "array",
          "items": {"type": "string"},
          "description": "References to artifacts affected by this decision"
        },
        "evidence_item_ref": {
          "type": "string",
          "description": "Optional reference to additional evidence"
        }
      },
      "required": ["review_item_ref", "decision", "decision_maker", "decision_timestamp", "rationale"]
    },
    {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/no_op_guard"}
  ],
  "unevaluatedProperties": false
}
