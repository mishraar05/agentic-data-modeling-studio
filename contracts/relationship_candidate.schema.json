{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:contract:relationship_candidate:0.2.0",
  "$comment": "Evidence-grounded relationship hypothesis produced by the LLM relationship analyst. It is contextual inference, never an observed source fact and never auto-approved.",
  "type": "object",
  "allOf": [
    {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/envelope"},
    {
      "properties": {
        "schema_version": {"const": "0.2.0"},
        "lifecycle_state": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/lifecycle_material"},
        "provenance": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/contextual_provenance"},
        "context_snapshot_ref": {"type": "string", "minLength": 1},
        "source_snapshot_ref": {"type": "string", "minLength": 1},
        "evidence_set_ref": {"type": "string", "minLength": 1},
        "parent_object_observation_ref": {"type": "string", "minLength": 1},
        "child_object_observation_ref": {"type": "string", "minLength": 1},
        "parent_object_name": {"type": "string", "minLength": 1},
        "child_object_name": {"type": "string", "minLength": 1},
        "parent_attributes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "child_attributes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "relationship_type": {"enum": ["FOREIGN_KEY", "INFERRED_FK", "LOOKUP", "BRIDGE", "SELF_REFERENCE"]},
        "relationship_name": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/semantic_claim"},
        "cardinality": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/semantic_claim"},
        "optionality": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/semantic_claim"},
        "rationale": {"type": "string", "minLength": 1},
        "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "memory_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "critic_status": {"enum": ["CONFIRMED", "CONTESTED", "NOT_ASSESSED"]},
        "review_decision_ref": {"type": "string", "minLength": 1},
        "open_question_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "required": [
        "context_snapshot_ref", "source_snapshot_ref", "evidence_set_ref",
        "parent_object_observation_ref", "child_object_observation_ref",
        "parent_object_name", "child_object_name", "parent_attributes", "child_attributes",
        "relationship_type", "relationship_name", "cardinality", "optionality",
        "rationale", "evidence_refs", "critic_status"
      ]
    },
    {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/material_approval_guard"}
  ],
  "unevaluatedProperties": false
}
