{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:contract:work_package:0.1.0",
  "$comment": "Work package defining one bounded execution slice by engagement, LOB, domain, source scope, and allowed table list. The solution operates on exactly one authorized work package at a time.",
  "type": "object",
  "allOf": [
    {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/envelope"},
    {
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "lifecycle_state": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/lifecycle_operational"},
        "provenance": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/provenance"},
        "engagement_ref": {"type": "string", "minLength": 1},
        "workflow_state": {"enum": ["VALIDATED", "METADATA_READY", "PROFILE_READY", "EVIDENCE_READY", "CONTEXT_READY", "SDD_READY", "SILVER_READY", "GOLD_READY", "STTM_READY", "PUBLISHED"]},
        "source_catalog": {"type": "string", "minLength": 1},
        "source_schema": {"type": "string", "minLength": 1},
        "source_tables_allow_list": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-zA-Z0-9_]+$"}
        },
        "source_product": {"type": "string"},
        "source_module": {"type": "string"},
        "source_version": {"type": "string"},
        "knowledge_pack_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "knowledge_pack_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "output_catalog": {"type": "string", "minLength": 1},
        "output_schema": {"type": "string", "minLength": 1},
        "authorization_validated_at": {"type": "string", "format": "date-time"},
        "notes": {"type": "string"}
      },
      "required": [
        "engagement_ref",
        "workflow_state",
        "source_catalog",
        "source_schema",
        "source_tables_allow_list",
        "output_catalog",
        "output_schema"
      ]
    },
    {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/no_op_guard"}
  ],
  "unevaluatedProperties": false
}
