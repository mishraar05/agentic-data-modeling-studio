{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:contract:business_rule:0.1.0",
  "$comment": "Business rule extracted from requirements with type and affected attributes.",
  "type": "object",
  "allOf": [
    {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/envelope"},
    {
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "lifecycle_state": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/lifecycle_material"},
        "provenance": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/provenance"},
        "solution_run_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to the solution run"
        },
        "evidence_item_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to supporting evidence"
        },
        "rule_text": {
          "type": "string",
          "minLength": 10,
          "description": "Full text of the business rule"
        },
        "rule_type": {
          "type": "string",
          "enum": ["VALIDATION", "CALCULATION", "TRANSFORMATION", "DERIVATION"],
          "description": "Classification of business rule"
        },
        "affected_attributes": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of attribute names affected by this rule"
        },
        "source_document_ref": {
          "type": "string",
          "description": "Reference to source document if from document_set"
        },
        "source_locator": {
          "type": "string",
          "description": "Page number or section identifier within document"
        },
        "review_decision_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to review decision (required when APPROVED)"
        }
      },
      "required": ["solution_run_ref", "evidence_item_ref", "rule_text", "rule_type"],
      "allOf": [
        {
          "if": {
            "properties": {"lifecycle_state": {"const": "APPROVED"}}
          },
          "then": {
            "required": ["review_decision_ref"]
          }
        }
      ]
    },
    {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/material_approval_guard"}
  ],
  "unevaluatedProperties": false
}
