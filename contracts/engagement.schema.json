{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:contract:engagement:0.1.0",
  "$comment": "Engagement scope and authorization record. Defines LOB, domain, client, authorization, effective dates, and deployment environment for one bounded modeling initiative.",
  "type": "object",
  "allOf": [
    {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/envelope"},
    {
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "lifecycle_state": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/lifecycle_operational"},
        "provenance": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/provenance"},
        "client_name": {"type": "string", "minLength": 1},
        "authorization_ref": {"type": "string", "minLength": 1},
        "effective_start_date": {"type": "string", "format": "date"},
        "effective_end_date": {"type": ["string", "null"], "format": "date"},
        "workspace_host": {"type": "string", "minLength": 1},
        "source_access_granted": {"type": "boolean"},
        "profiling_policy": {"enum": ["FULL", "METADATA_ONLY", "RESTRICTED"]},
        "output_catalog": {"type": "string", "minLength": 1},
        "output_schema": {"type": "string", "minLength": 1},
        "notes": {"type": "string"}
      },
      "required": [
        "client_name",
        "authorization_ref",
        "effective_start_date",
        "workspace_host",
        "source_access_granted",
        "profiling_policy",
        "output_catalog",
        "output_schema"
      ]
    },
    {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/no_op_guard"}
  ],
  "unevaluatedProperties": false
}
