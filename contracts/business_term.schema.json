{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:contract:business_term:0.1.0",
  "$comment": "Business term with definition and optional mapping to governed glossary.",
  "type": "object",
  "allOf": [
    {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/envelope"},
    {
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "lifecycle_state": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/lifecycle_material"},
        "provenance": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/provenance"},
        "work_package_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to the work package"
        },
        "evidence_item_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to supporting evidence"
        },
        "term": {
          "type": "string",
          "minLength": 1,
          "description": "The business term"
        },
        "definition": {
          "type": "string",
          "minLength": 10,
          "description": "Business definition of the term"
        },
        "synonyms": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Alternative terms with same meaning"
        },
        "governed_equivalent": {
          "type": "string",
          "description": "Mapping to equivalent term in governed glossary"
        },
        "source_document_ref": {
          "type": "string",
          "description": "Reference to source document if from document_set"
        },
        "source_locator": {
          "type": "string",
          "description": "Page number or section identifier within document"
        },
        "review_decision_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to review decision (required when APPROVED)"
        }
      },
      "required": ["work_package_ref", "evidence_item_ref", "term", "definition"],
      "allOf": [
        {
          "if": {
            "properties": {"lifecycle_state": {"const": "APPROVED"}}
          },
          "then": {
            "required": ["review_decision_ref"]
          }
        }
      ]
    },
    {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/material_approval_guard"}
  ],
  "unevaluatedProperties": false
}
