{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:contract:reporting_requirement:0.1.0",
  "$comment": "Captured reporting requirement from business documents, with optional metric and calculation details.",
  "type": "object",
  "allOf": [
    {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/envelope"},
    {
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "lifecycle_state": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/lifecycle_material"},
        "provenance": {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/provenance"},
        "solution_run_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to the solution run"
        },
        "evidence_item_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to supporting evidence"
        },
        "requirement_text": {
          "type": "string",
          "minLength": 10,
          "description": "Full text of the requirement"
        },
        "acceptance_criteria": {
          "type": "string",
          "minLength": 1,
          "description": "Criteria for requirement satisfaction"
        },
        "priority": {
          "type": "string",
          "enum": ["MUST", "SHOULD", "NICE_TO_HAVE"],
          "description": "Requirement priority"
        },
        "report_name": {
          "type": "string",
          "description": "Name of the report or dashboard"
        },
        "metric_name": {
          "type": "string",
          "description": "Name of the specific metric"
        },
        "calculation_logic": {
          "type": "string",
          "description": "Business logic for metric calculation"
        },
        "source_document_ref": {
          "type": "string",
          "description": "Reference to source document if from document_set"
        },
        "source_locator": {
          "type": "string",
          "description": "Page number or section identifier within document"
        },
        "review_decision_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to review decision (required when APPROVED)"
        }
      },
      "required": ["solution_run_ref", "evidence_item_ref", "requirement_text", "acceptance_criteria", "priority"],
      "allOf": [
        {
          "if": {
            "properties": {"lifecycle_state": {"const": "APPROVED"}}
          },
          "then": {
            "required": ["review_decision_ref"]
          }
        }
      ]
    },
    {"$ref": "urn:agentic-data-modeler:contract:common:0.4.0#/$defs/material_approval_guard"}
  ],
  "unevaluatedProperties": false
}
