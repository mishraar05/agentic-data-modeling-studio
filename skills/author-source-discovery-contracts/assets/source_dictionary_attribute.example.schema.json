{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentic-data-modeler:contract:source_dictionary_attribute:0.1.0",
  "$comment": "Worked example only. The neutral scaffold is record.schema.template.json.",
  "type": "object",
  "allOf": [
    {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/envelope"},
    {
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "lifecycle_state": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/lifecycle_material"},
        "provenance": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/contextual_provenance"},
        "source_system_id": {"type": "string", "minLength": 1},
        "source_attribute_observation_ref": {"type": "string", "minLength": 1},
        "schema_name": {"type": "string", "minLength": 1},
        "object_name": {"type": "string", "minLength": 1},
        "attribute_name": {"type": "string", "minLength": 1},
        "ordinal_position": {"type": "integer", "minimum": 1},
        "physical": {
          "type": "object",
          "required": ["data_type", "nullable", "evidence_refs"],
          "properties": {
            "data_type": {"type": "string", "minLength": 1},
            "length": {"type": ["integer", "null"], "minimum": 0},
            "precision": {"type": ["integer", "null"], "minimum": 0},
            "scale": {"type": ["integer", "null"], "minimum": 0},
            "nullable": {"type": "boolean"},
            "default": {"type": ["string", "null"]},
            "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
          },
          "additionalProperties": false
        },
        "profile_evidence_ref": {"type": ["string", "null"]},
        "business_name": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/semantic_claim"},
        "business_definition": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/semantic_claim"},
        "business_purpose": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/semantic_claim"},
        "subject_area": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/semantic_claim"},
        "synonyms": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/semantic_claim"},
        "lifecycle_meaning": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/semantic_claim"},
        "sensitivity_class": {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/semantic_claim"},
        "review_decision_ref": {"type": "string", "minLength": 1}
      },
      "required": [
        "source_system_id",
        "source_attribute_observation_ref",
        "schema_name",
        "object_name",
        "attribute_name",
        "ordinal_position",
        "physical",
        "business_definition"
      ]
    },
    {"$ref": "urn:agentic-data-modeler:contract:common:0.3.0#/$defs/material_approval_guard"}
  ],
  "unevaluatedProperties": false
}
